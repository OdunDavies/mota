{
  "name": "sarkimota",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "supabase gen types typescript --linked > packages/database/src/schema.ts",
    "db:migrate": "supabase db push",
    "db:seed": "tsx supabase/seed/index.ts",
    "ci": "turbo lint typecheck build"
  },
  "devDependencies": {
    "@sarkimota/eslint-config": "workspace:*",
    "@sarkimota/typescript-config": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.5.0",
    "pg": "^8.21.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tsx": "^4.22.3",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
